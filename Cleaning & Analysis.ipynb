###___________________________________SALES V/S PROFIT ANALYSIS_____________________________________###
###___________________________Bubble Chart (Scatter Plot with size + categories + subcategory)_____________________________###

#data

####copied sample
scatter_plot = data.groupby(['Category','Sub-Category']).agg({
    'Sales':'sum',
    'Profit':'sum'
}).reset_index()

# Reduce clutter
scatter_plot = scatter_plot.sort_values(by='Sales', ascending=False).head(15).reset_index()

#style and plot sizee
sns.set_style("whitegrid")
plt.figure(figsize=(10,6))

sns.scatterplot(
    data=scatter_plot,
    x='Sales',
    y='Profit',
    hue='Category',
    size='Sales',
    sizes=(50,500),
    alpha=0.7       #alpha shows transparency in line range 0-1
)

# Better labels
for i in range(len(scatter_plot)):
    plt.text(
        scatter_plot['Sales'][i] + 20,
        scatter_plot['Profit'][i] + 20,
        scatter_plot['Sub-Category'][i],
        fontsize=8     #size of text
    )

# Average lines
plt.axvline(scatter_plot['Sales'].mean(), linestyle='--', color='gray')
plt.axhline(scatter_plot['Profit'].mean(), linestyle='--', color='gray')

plt.text(scatter_plot['Sales'].mean()*1.5, scatter_plot['Profit'].mean()*2, "High Value", color='green')
plt.text(scatter_plot['Sales'].mean()*0.25, scatter_plot['Profit'].mean()*2, "Opportunity", color='blue')
plt.text(scatter_plot['Sales'].mean()*1.5, scatter_plot['Profit'].mean()*0.15, "Low Margin", color='red')
plt.text(scatter_plot['Sales'].mean()*0.25, scatter_plot['Profit'].mean()*0.15, "Low Impact", color='gray')
                #{*1.5 specify the location of text}
#title and label
plt.title("Sales vs Profit by Sub-Category")
plt.xlabel("Sales")
plt.ylabel("Profit")

plt.legend(bbox_to_anchor=(1.05,1))
plt.tight_layout()

plt.show()

