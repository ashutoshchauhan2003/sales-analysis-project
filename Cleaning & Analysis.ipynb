##_________________________________Box Plot (Sales by Region and category)______________________________##

#data
box_plot = data.groupby(['Region','Category','Sub-Category'])['Sales'].sum().reset_index()

#style & plot size
sns.set_style("whitegrid")
plt.figure(figsize=(10,6))

#plot boxplot
