#title and labels
plt.title("Sales Distribution by Region & Category")
plt.xlabel("Region")
plt.ylabel("Sales")

plt.show()

###_______________________________________________ADVANCE ANALYTICS____________________________________________###
##_______________________________________Correlation Heatmap________________________________________##

#data preperation
correlation = data.corr(numeric_only=True)
mask = np.triu(np.ones_like(correlation, dtype=bool))

#style & size
sns.set_style("whitegrid")
plt.figure(figsize=(10,6))

#plot map
sns.heatmap(correlation, mask=mask, annot=True, fmt=".2f", cmap='coolwarm', center=0, linewidths=0.5)

#title
plt.title("Correlation Heatmap", fontsize=14, color='red')
plt.show()
