import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np
from datetime import datetime as dt

###__________________________________________data load___________________________________________###

# Load dataset
data = pd.read_csv("C:\\Users\\Ashutosh Chauhan\\Desktop\\ashu\\Superstore.csv")

#Data Cleaning
data.nunique()

#Convert Date
data['Row ID'] = data['Row ID'].astype(object)
data['Postal Code'] = data['Postal Code'].astype(object)
data['Order Date'] = pd.to_datetime(data['Order Date'],format='%m/%d/%Y')
data['Ship Date'] = pd.to_datetime(data['Ship Date'],format='%m/%d/%Y')
data['Sales'] = data['Sales'].round(2)
data['Profit'] = data['Profit'].round(2)

#Basic Info
print("***______________________________________SUPERSTORE__________________________________________***")
print("Table view\n",data.head())
print("About table\n")
print(data.info())
print("Statistical analytics of table\n",data.describe())

###____________________________________Sales & Profit & Time-Based Analysis________________________________________###

total_sales = data['Sales'].sum().round(2)
total_profit = data['Profit'].sum().round(2)
profit_margin = (total_profit/total_sales*100).round(2)

##_______________time series analysis_____________________##
data['Order Month'] = data['Order Date'].dt.month
monthly_sales_trend = data.groupby('Order Month')['Sales'].sum().reset_index()
monthly_profit_trend = data.groupby('Order Month')['Profit'].sum().reset_index()
data['Order Year'] = data['Order Date'].dt.year
yearly_sales_trend = data.groupby('Order Year')['Sales'].sum().reset_index()
yearly_profit_trend = data.groupby('Order Year')['Profit'].sum().reset_index()

##__________________identify_____________________##
top5_selling_product = data.groupby('Product Name')['Sales'].sum().reset_index()
most_profitable_product = data.groupby('Product Name')['Profit'].sum().reset_index()
loss_making_product = data.groupby('Product Name')['Discount'].sum().reset_index()
lest_profit_product = data.groupby('Product Name')['Profit'].sum().min(0)

##__________________insights____________________##
product_info = data.groupby('Product Name').agg({'Sales': 'sum','Profit':'sum'}).reset_index(0)
high_sale_products = product_info['Sales'].quantile(0.75)
low_profit_products = product_info['Profit'].quantile(0.25)
product_highsale_lowprofit = product_info[(product_info['Sales']>= high_sale_products)&(product_info['Profit']<=low_profit_products)]
discount_profit = data['Discount'].corr(data['Profit']).__round__(4)

#____________________result________________#
print("=====================SALES AND PROFIT ANALYSIS===================")
print("total_sales:",total_sales)
print("total_profit:",total_profit)
print("profit_margin:",profit_margin)
print("top_5_selling_product:\n",top5_selling_product.sort_values(by='Product Name',ascending=False).head(5))
print("most_profitable_product:\n",most_profitable_product.sort_values(by='Profit',ascending=False).head(5))
print("loss_making_product:\n",loss_making_product.sort_values(by='Discount',ascending=False).head(3))
print("INSIGHTS-")
print("product that have highest sales but low profit")
print(product_highsale_lowprofit.sort_values(by='Sales', ascending=False))
if discount_profit<=0:
    print("corelation between discount and profit is-",discount_profit,"this negative results shows, discount are likely hurting profit")
else:
    print("corelation between discount and profit is-",discount_profit,"this shows, discount can't be hurting the profit")
print("=======================Time - based Analysis===============================")
print("monthly_sales_trend:")
print(monthly_sales_trend)
print("monthly_profit_trend:")
print(monthly_profit_trend)
print("yearly_sales_trend:")
print(yearly_sales_trend)
print("yearly_profit_trend:")
print(yearly_profit_trend)

###_________________________________________________customer & Segment analysis______________________________________________###
segment_info = data.groupby('Segment').agg({'Sales':'sum','Profit':'sum'})
segment_info.columns = ['revenue','profit']
customer_info = data.groupby(['Customer ID','Customer Name']).agg({'Sales':['sum','mean','count'],'Order Date':['min','max']})
customer_info.columns = ['total_spend','avg_purchase','purchase_frequency','first_purchase','last_purchase']

#customer_lifespam_calculation
customer_info['lifespan_days'] = (customer_info['last_purchase']-customer_info['first_purchase']).dt.days
customer_info['lifespam_years'] = (customer_info['lifespan_days']/365).round(2)

#calculation life-time value
customer_info['CLV'] = (customer_info['avg_purchase']*customer_info['purchase_frequency']*customer_info['lifespam_years']).__round__(2)

#repeat v/s new customer
cust_detail = data.groupby('Customer ID')['Order Date'].count().reset_index()
cust_detail.columns = ['Customer ID','order count']
cust_detail['customer type'] = cust_detail['order count'].apply(lambda x: 'new' if x==1 else 'repeat')
merge_data = data.merge(cust_detail[['Customer ID','customer type']],on='Customer ID',how='left')
count_new_repeat = merge_data.groupby('customer type').value_counts()
revenue_comparision_by_NR = merge_data.groupby('customer type')['Sales'].sum()

#insights
most_spending_customer = data.groupby(['Customer ID','Customer Name'])['Sales'].sum().reset_index()
most_spending_customer.columns = ['CUSTOMER_ID','NAME','SPEND']

#_______________________result_______________#

print("==============================CUSTOMER ANALYSIS====================")

print("###Customer Information###")
print(customer_info[['total_spend','avg_purchase','purchase_frequency','first_purchase','last_purchase']].sort_values(by='total_spend',ascending=False))
print("Most valuable customer:\n","highest customer life time value customer-")
print(customer_info['CLV'].sort_values(ascending=False).head(7))
print("Most spending customer-")
print(most_spending_customer.sort_values(by='SPEND',ascending=False).head(7))


print("==========================Segment Analysis========================")

print("###Segment Information###")
print(segment_info)
print("Most profitale segment:\n",segment_info.sort_values(by='profit',ascending=False).head(1))

###________________________________________________________VISUALIZATION____________________________________________###

###__________Sales Visualization_______________###

#Sales by Category
category_by_sales = data.groupby('Category')['Sales'].sum()
most_sale_category = data.groupby('Category')['Sales'].sum().max()
color = category_by_sales.apply(lambda x: 'g' if x==most_sale_category else 'y')
sns.set_style("darkgrid")
category_by_sales.plot(kind='bar',color=color)
plt.title("Sales by Category")
plt.ylabel("Sales")
plt.show()

#Sales share of per segment
sales_segment = data.groupby('Segment')['Sales'].sum()
sales_segment.plot(kind='pie', autopct='%1.1f%%', startangle=270) #autopct show percentage and .1f%% denoted 1 decimal value
plt.title("Sales share of per segment")
plt.show()

#Monthly Sales Trend by Category
monthlysales_by_product = data.groupby(['Order Month','Category'])['Sales'].sum().reset_index()
sns.set_style("whitegrid")
sns.lineplot(x='Order Month',y='Sales', data=monthlysales_by_product,style="Category", hue='Category')
plt.title("Monthly Sales Trend by Category")
plt.grid(True, linestyle='--', alpha=0.5)
plt.show()

#Regional Sales with product
sales_category_with_region = data.groupby(['Region','Category'])['Sales'].sum().reset_index()
sns.set_style("dark")
sns.barplot(x='Region',y='Sales',hue='Category',data=sales_category_with_region)
plt.title("Regional Sales with product")
plt.show()

